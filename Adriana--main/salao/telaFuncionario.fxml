<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1">

    <!-- Título -->
    <Label text="Cadastro de Funcionário"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <!-- Campo Nome -->
    <TextField fx:id="nomeField" promptText="Nome" />

    <!-- Campo Função -->
    <TextField fx:id="funcaoField" promptText="Função" />

    <!-- Campo Idade -->
    <TextField fx:id="idadeField" promptText="Idade" />

    <!-- Botões -->
    <Button text="Fazer Aniversário" fx:id="aniversarioButton" />
    
    <Button text="Iniciar Turno" fx:id="turnoButton" />
    
    <Button text="Promover" fx:id="promoverButton" />
    
    <Button text="Buscar Info" fx:id="buscarButton" />

</VBox>